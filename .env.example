# Required for the Strategy Copilot RAG chatbot
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: MongoDB Atlas connection string for prediction/research logging
# Without this, the API works normally — logging silently no-ops
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
